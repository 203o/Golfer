# Frontend (Flutter web)
API_BASE_URL=http://localhost:8000

# Backend (FastAPI)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Firebase Admin (pick ONE approach)
# 1) Local service account file path
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=credentials/firebase-service-account-key.json

# 2) OR full JSON in env (leave empty if using file path)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional split vars alternative
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# M-Pesa (Daraja)
DARAJA_LIVE=false
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
DARAJA_SHORTCODE=
DARAJA_PASSKEY=
DARAJA_CALLBACK_URL=http://localhost:8000/api/v1/mpesa/callback
