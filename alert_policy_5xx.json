{
  "displayName": "Golfer-api 5xx error rate > 1% (5m)",
  "combiner": "OR",
  "enabled": true,
  "documentation": {
    "content": "5xx error ratio for Cloud Run service `Golfer-api` exceeded 1% for 5 minutes.",
    "mimeType": "text/markdown"
  },
  "conditions": [
    {
      "displayName": "Cloud Run 5xx ratio > 1%",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.label.service_name=\"Golfer-api\" AND metric.type=\"run.googleapis.com/request_count\" AND metric.label.response_code_class=\"5xx\"",
        "denominatorFilter": "resource.type=\"cloud_run_revision\" AND resource.label.service_name=\"Golfer-api\" AND metric.type=\"run.googleapis.com/request_count\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 0.01,
        "duration": "300s",
        "trigger": {
          "count": 1
        },
        "aggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM",
            "groupByFields": [
              "resource.label.service_name"
            ]
          }
        ],
        "denominatorAggregations": [
          {
            "alignmentPeriod": "60s",
            "perSeriesAligner": "ALIGN_RATE",
            "crossSeriesReducer": "REDUCE_SUM",
            "groupByFields": [
              "resource.label.service_name"
            ]
          }
        ]
      }
    }
  ],
  "userLabels": {
    "service": "Golfer-api",
    "env": "prod"
  }
}
